    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    TO_CHAR(date, 'YYYY-MM-DD') AS date,\n    SUM(total) AS total_ventas \nFROM sales \nWHERE job_id IN (\n    SELECT id FROM jobs \n    WHERE status IN ('COMPLETED', 'COMPLETED_WITH_ERRORS')\n)\nGROUP BY date \nORDER BY date",
        "options": {}
      },
