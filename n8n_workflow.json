    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO sales_daily_summary (date, total_ventas, created_at, updated_at) VALUES ('{{ $json.date }}', {{ $json.total_ventas }}, NOW(), NOW()) ON CONFLICT (date) DO UPDATE SET total_ventas = EXCLUDED.total_ventas, updated_at = NOW();",
